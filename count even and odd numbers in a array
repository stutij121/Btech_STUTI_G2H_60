#include <stdio.h>
int main()
{
int a[10],i,n,even=0,odd=0;
printf("enter the number of elements :");
scanf("%d",& n);

for(i=0;i<n;i++)
{
    scanf("%d",&a[i]);
}

 for(i=0;i<n;i++)
{
    if(a[i]%2==0)
    even++;
    else
    odd++;
}
printf("number of even elements=%d",even);
printf("number of odd elements=%d",odd);

return 0;
}

