#include<stdio.h>
#include<math.h>
int main()
{
    int binary,decimal=0;
    int remainder,position=0;
 printf("enter a binary number");
 scanf("%d",& binary);
  
 while (binary!=0)
 {
    
 remainder=binary%10;
 decimal=decimal+remainder*pow(2,position);

 binary=binary/10;
 position++;
}
printf("decimal number becomes %d",decimal);
return 0;
}
